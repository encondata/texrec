# copy to .env next to docker-compose.yml and edit

# --- database (postgres container credentials; app connects with the same) ---
PGDATABASE=texrec
PGUSER=texrec
PGPASSWORD=pick-a-strong-db-password
# PGHOST/PGPORT are fixed to the compose db service — no need to set them here

# --- web ---
HOST_PORT=80
# bind the published port to a specific host IP (default: all interfaces).
# set to a dedicated host IP if you assigned one for the app, e.g. 10.10.48.7
# (that IP must already exist on the host — see README "Serving on a dedicated IP").
BIND_IP=0.0.0.0
# comma-separated allowed origins, or * to allow any (dev/testing only!)
# production example: CORS_ORIGIN=https://texrec.com,https://www.texrec.com
CORS_ORIGIN=*

# --- session lifetimes ---
# staff portal sign-ins expire after this many hours
ADMIN_TOKEN_HOURS=12
# customer portal sign-ins expire after this many days
CUSTOMER_TOKEN_DAYS=7

# --- first admin account: created on first boot only, if no admins exist ---
BOOTSTRAP_ADMIN_EMAIL=admin@texrec.com
BOOTSTRAP_ADMIN_PASSWORD=pick-a-strong-admin-password
BOOTSTRAP_ADMIN_NAME=TexRec Admin
